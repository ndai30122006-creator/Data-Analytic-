# ── Environment Configuration for Learning Analytics ──
# Copy this file to .env and adjust values for your environment.
# DO NOT commit .env to version control (it's in .gitignore).

# ── Application Mode ──
ENVIRONMENT=development
# production / development

# ── Demo Credentials ──
# If DEMO_MODE=true, these accounts will be auto-created on first run.
# CHANGE THESE PASSWORDS before deploying to production.
DEMO_MODE=true
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD=admin123
DEMO_USER_USERNAME=user
DEMO_USER_PASSWORD=user123
DEMO_TEACHER_USERNAME=teacher
DEMO_TEACHER_PASSWORD=teacher123

# ── Database ──
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/learning_analytics
# For development, SQLite is used by default:
# DATABASE_URL=sqlite:///./users.db

# ── JWT Authentication ──
# Generate a strong secret key for production:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CORS ──
# Comma-separated list of allowed origins (no spaces after commas)
# ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8000
# For production, set to your actual domain(s):
# ALLOWED_ORIGINS=https://your-app.com
# CORS_ALLOW_ALL=false (set to true only for development)

# ── AI / LLM ──
# Provider: "openai" or "gemini"
AI_PROVIDER=openai
# Your OpenAI API key (starts with "sk-...")
AI_API_KEY=

# ── Redis (optional, for rate limiting) ──
# REDIS_URL=redis://localhost:6379/0

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=60